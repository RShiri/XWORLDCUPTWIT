# .env.template — copy to .env at the repo root and fill in values.
# .env is git-ignored (see .gitignore). NEVER commit real secrets.
# run_match.py / pipeline.py auto-load this via python-dotenv.

# ── Git publishing (REQUIRED for the live site to auto-update) ───────────────
# GitHub Personal Access Token with WRITE (contents) access to the repo below.
# Fine-grained: repo XWORLDCUPTWIT -> Repository permissions -> Contents: Read & write.
# Classic: scope `repo`.  Verify with:  curl -s -H "Authorization: token <TOKEN>" \
#   https://api.github.com/user   ->  must return your login, not "Bad credentials".
# If this is missing/expired, the per-match auto-push fails SILENTLY (run_match logs
# "Git push failed (continuing)") — scrape/render still run, but nothing reaches the site.
GIT_TOKEN=
XWORLDCUPTWIT_REPO=https://github.com/RShiri/XWORLDCUPTWIT.git
XWORLDCUPTWIT_BRANCH=main
XWORLDCUPTWIT_SUBDIR=WorldCup2026

# ── Scraping ────────────────────────────────────────────────────────────────
# Run Chrome visibly so you can clear the WhoScored Cloudflare CAPTCHA by hand.
WC2026_VISIBLE=1
# FotMob league id for WC2026 (only override if the tournament id changes).
WC2026_FOTMOB_LEAGUE_ID=

# ── WhatsApp match alerts (optional; run_match step 5) ───────────────────────
# Provider: "callmebot" or "twilio". Leave blank / use --no-post to skip.
WHATSAPP_PROVIDER=
WHATSAPP_PHONE=
WHATSAPP_CALLMEBOT_KEY=
WHATSAPP_TWILIO_SID=
WHATSAPP_TWILIO_TOKEN=
WHATSAPP_TWILIO_FROM=

# ── Twitter/X posting (optional; LEGACY tools/twitter_bot.py only) ───────────
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# ── Legacy file-watcher pipeline (tools/pipeline.py) tuning — optional ───────
WC2026_POLL_SECONDS=
WC2026_SCRAPE_POLL_SECONDS=
WC2026_TWEET_DELAY_SECONDS=
WC2026_WEBHOOK_SECRET=
